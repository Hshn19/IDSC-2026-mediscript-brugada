cat >> .gitignore << 'EOF'

# Dataset — never commit raw ECG files
data/files/
data/*.dat
data/*.hea
data/metadata.csv
data/RECORDS

# Model checkpoints — too large for git
outputs/checkpoints/*.pt
outputs/checkpoints/*.pth

# Colab / Jupyter artifacts
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db
EOF

outputs/splits.json
# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo

# Model checkpoints
outputs/checkpoints/*.pt
outputs/checkpoints/*.pth

# Numpy outputs
outputs/*.npy

# Training outputs
outputs/training_history.json
outputs/splits.json